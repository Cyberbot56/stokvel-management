generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model users {
  id         String   @id @default(dbgenerated("newid()")) // id is in string for security reasons like IDOR
  providerId String   @unique // this is auth0's id for tracking its users not primary key
  email      String   @unique // Jus email
  name       String
  createdAt  DateTime @default(now())
}
